create table if not exists public.direct_message_threads (
  id uuid primary key default gen_random_uuid(),
  user_low uuid not null references public.profiles(id) on delete cascade,
  user_high uuid not null references public.profiles(id) on delete cascade,
  created_at timestamptz not null default now(),
  updated_at timestamptz not null default now(),
  constraint direct_message_threads_not_self check (user_low <> user_high),
  constraint direct_message_threads_unique_pair unique (user_low, user_high)
);

create table if not exists public.direct_messages (
  id uuid primary key default gen_random_uuid(),
  thread_id uuid not null references public.direct_message_threads(id) on delete cascade,
  sender_id uuid not null references public.profiles(id) on delete cascade,
  content text not null,
  created_at timestamptz not null default now(),
  is_deleted boolean not null default false,
  constraint direct_messages_content_not_blank check (length(trim(content)) > 0)
);

create index if not exists idx_direct_message_threads_user_low
  on public.direct_message_threads(user_low);

create index if not exists idx_direct_message_threads_user_high
  on public.direct_message_threads(user_high);

create index if not exists idx_direct_messages_thread_id_created_at
  on public.direct_messages(thread_id, created_at);

alter table public.direct_message_threads enable row level security;
alter table public.direct_messages enable row level security;

drop policy if exists "Users can view their own dm threads"
on public.direct_message_threads;

create policy "Users can view their own dm threads"
on public.direct_message_threads
for select
to authenticated
using (
  auth.uid() = user_low
  or auth.uid() = user_high
);

drop policy if exists "Users can view messages from their own dm threads"
on public.direct_messages;

create policy "Users can view messages from their own dm threads"
on public.direct_messages
for select
to authenticated
using (
  exists (
    select 1
    from public.direct_message_threads t
    where t.id = direct_messages.thread_id
      and (t.user_low = auth.uid() or t.user_high = auth.uid())
  )
);

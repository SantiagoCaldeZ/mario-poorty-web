create table public.friendships (
  id uuid primary key default gen_random_uuid(),

  requester_id uuid not null references public.profiles(id) on delete cascade,
  addressee_id uuid not null references public.profiles(id) on delete cascade,

  user_low uuid not null references public.profiles(id) on delete cascade,
  user_high uuid not null references public.profiles(id) on delete cascade,

  status text not null check (status in ('pending', 'accepted', 'rejected', 'blocked')) default 'pending',

  created_at timestamptz not null default now(),
  updated_at timestamptz not null default now(),

  constraint friendships_no_self check (requester_id <> addressee_id),
  constraint friendships_order_check check (user_low <> user_high),
  constraint friendships_unique_pair unique (user_low, user_high)
);

alter table public.matches
drop constraint if exists matches_phase_check;

alter table public.matches
add column if not exists current_character_turn_order integer;

do $$
begin
  if not exists (
    select 1
    from pg_constraint
    where conname = 'matches_phase_check'
  ) then
    alter table public.matches
    add constraint matches_phase_check
    check (phase in ('choosing_order', 'choosing_character', 'active', 'finished', 'abandoned'));
  end if;
end $$;
